# Go API
PORT=:8080
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000
AUTH_SUCCESS_REDIRECT_URL=http://localhost:3000
APP_SESSION_TTL=15m
APP_REFRESH_TTL=720h
AUTH_CLEANUP_INTERVAL=10m
ACCESS_PRINCIPAL_CACHE_TTL=30s

# Python service URL
PYTHON_SERVICE_URL=http://localhost:8000

# Azure Blob Storage for direct document uploads
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_BLOB_CONTAINER=documents
# Optional. Defaults to https://<account>.blob.core.windows.net/
AZURE_STORAGE_ENDPOINT=
DOCUMENT_UPLOAD_URL_TTL=15m

# Cookies - adjust for your environment
# For local dev use `localhost` and `APP_COOKIE_SECURE=false`
APP_COOKIE_DOMAIN=localhost
APP_COOKIE_SECURE=false
APP_COOKIE_SAME_SITE=Lax

# Database (Postgres example)
# Example: postgres://user:password@localhost:5432/auditGO?sslmode=disable
DB_URL=postgres://user:password@localhost:5432/audit?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m
DB_CONN_MAX_IDLE_TIME=2m

# Python service
OPENAI_API_KEY=sk-...

# Microsoft Entra ID (Azure AD) configuration
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URL=http://localhost:8080/auth/callback
